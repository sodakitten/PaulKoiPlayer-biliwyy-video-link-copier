{
  "manifest_version": 3,
  "name": "PaulKoiPlayer B站网易云链接复制器",
  "short_name": "PK链接复制",
  "version": "13.0.0",
  "description": "一键复制 B 站视频/直播/分 P 和网易云音乐/歌单的播放器解析地址或媒体直链，适配 PaulKoiPlayer / YamaPlayer。",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "clipboardWrite",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.bilibili.com/*",
    "https://live.bilibili.com/*",
    "https://api.bilibili.com/*",
    "https://api.live.bilibili.com/*",
    "https://*.bilivideo.com/*",
    "https://*.hdslb.com/*",
    "*://music.163.com/*",
    "*://y.music.163.com/*",
    "*://m.music.163.com/*",
    "*://163cn.tv/*",
    "https://music.znnu.com/*"
  ],
  "action": {
    "default_title": "复制播放链接"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
